generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum OrderStatus {
  RECEIVED
  PROCESSING
  ENRICHED
  FAILED_ENRICHMENT
}

model Order {
  id               String       @id @default(cuid())
  externalOrderId  String       @map("external_order_id")
  idempotencyKey   String       @unique @map("idempotency_key")
  customerEmail    String       @map("customer_email")
  customerName     String       @map("customer_name")
  currency         String
  totalAmount      Decimal      @db.Decimal(12, 2) @map("total_amount")
  status           OrderStatus  @default(RECEIVED)
  enrichedAmount   Decimal?     @db.Decimal(12, 2) @map("enriched_amount")
  enrichedCurrency String?      @map("enriched_currency")
  enrichmentPayload Json?       @map("enrichment_payload")
  failureReason    String?      @map("failure_reason")
  items            OrderItem[]
  createdAt        DateTime     @default(now()) @map("created_at")
  updatedAt        DateTime     @updatedAt @map("updated_at")

  @@index([status])
  @@index([externalOrderId])
  @@map("orders")
}

model OrderItem {
  id        String   @id @default(cuid())
  orderId   String   @map("order_id")
  sku       String
  qty       Int
  unitPrice Decimal  @db.Decimal(12, 2) @map("unit_price")
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([orderId])
  @@map("order_items")
}
